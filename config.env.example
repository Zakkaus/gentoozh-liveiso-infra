# gig-os 自动构建的敏感/环境配置模板。
# 用法:复制为同目录的 config.env,填入真实值,并 chmod 600。
#   cp config.env.example /opt/live-iso-builder/config.env && chmod 600 /opt/live-iso-builder/config.env
# config.env 已被 .gitignore 排除,绝不提交。被 build-and-deploy.sh / reupload-iso.sh 在运行时 source。

# ── 下载站部署目标(build → mirror 的 SSH/SCP)──
M_HOST=mirror.example.org          # 下载站地址或 IP
M_PORT=22                          # SSH 端口
M_USER=root                        # 部署用户
M_KEY=/root/.ssh/mirror_deploy     # 部署私钥路径(公钥需加到下载站 authorized_keys)
M_ISODIR=/srv/mirror/iso           # 下载站 ISO 目录
KEEP=2                             # 下载站保留最近几个 ISO(随盘容量定:上线峰值约 (KEEP+1)×单盘,20G 盘+4G 盘建议 2)

# ── 端到端核对:镜像站对外 HTTPS 地址(确认"站上实际服务的就是本锅",防"编译了没更新")──
# M_URLBASE 必须是 M_ISODIR 对应的【公开 URL 目录】(末尾不带斜杠);对外路径前缀无法从外部探测,
# 必须显式声明。留空则跳过对外核对(强烈建议配上)。首次部署后用一次真实上线 curl 验证它正确。
M_URLBASE=https://mirror.example.org/iso   # 公开 ISO 目录(拼 ${M_URLBASE}/<iso>.sha256)
M_PAGEURL=https://mirror.example.org/      # 落地页(核对是否含本锅文件名+SHA);默认站点根

# ── Telegram 构建通知(可选,留空则不通知)──
# 创建 bot(@BotFather)、把它设为目标频道的管理员。
TG_TOKEN=                          # bot token,如 123456:ABC...
TG_CHAT=                           # 频道,如 @your_channel

# ── Cloudflare R2(可选,ISO 第二上传目标;零出口流量,适合大文件公开下载;留空则跳过)──
# Cloudflare → R2 → Manage API Tokens 建【Object Read & Write、限定该 bucket】的 token;
# 构建机需装 rclone(static binary 即可);公开下载走 R2 → Custom Domains 绑定的自定义域。
R2_ACCESS_KEY_ID=                  # R2 token 的 Access Key ID
R2_SECRET_ACCESS_KEY=             # R2 token 的 Secret Access Key
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com   # 账户级 S3 端点(不含 bucket)
R2_BUCKET=gentoozh                # bucket 名
R2_KEEP=3                         # R2 保留最近几个 ISO(R2 便宜,可比下载站多留)
R2_PUBLIC_BASE=https://r2.gentoozh.org   # 绑定到 bucket 的自定义公开域(末尾不带斜杠)
